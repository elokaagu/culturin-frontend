# App
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Database (Supabase Postgres)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres
# Public reads for cms_* tables (browser + ISR). Create in Supabase → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-anon-key

# OAuth (NextAuth Google provider)
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# OpenAI (used by /api/chat)
OPENAI_API_KEY=replace-with-openai-api-key

# CMS (Payload-style pages API for /articles hero copy — omit in production if you rely on fallbacks only)
NEXT_PUBLIC_CMS_BASE_URL=http://localhost:4000
# Optional: override default Payload page id for /articles landing
# NEXT_PUBLIC_CMS_ARTICLES_LANDING_ID=65b25faecac4c3b01971d7d2
# Optional: only sent when set (never use the literal string "undefined")
# NEXT_PUBLIC_CMS_LOCALE=en

# Clerk (optional; required only if you want Clerk routes/components active)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# Mapbox (country explorer map — public token ok for client bundles)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=replace-with-mapbox-public-token

# Legacy (only if you still run old Mongo scripts/routes)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/culturin?retryWrites=true&w=majority
