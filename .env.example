# App
NODE_ENV=development

# Database (Supabase Postgres)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres
# Public: browser auth + CMS reads. Create in Supabase → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-anon-key
# Optional aliases (server + next.config will mirror to NEXT_PUBLIC_* for the client bundle if the names above are unset):
# SUPABASE_URL= same as above
# SUPABASE_ANON_KEY= same as anon key above

# Supabase Storage: public bucket `media` for uploads (see supabase/migrations/004_storage_media_bucket.sql).
# Public URLs look like: {NEXT_PUBLIC_SUPABASE_URL}/storage/v1/object/public/media/{userId}/{file}

# Supabase Auth: enable Email + Google under Authentication → Providers.
# Production: set to your deployed origin (no trailing slash). Email confirmation + OAuth use this
# so links are never localhost when users sign up on https://your-app.vercel.app
# NEXT_PUBLIC_SITE_URL=https://culturin-frontend.vercel.app
#
# In Supabase Dashboard → Authentication → URL Configuration:
# - Site URL: same as production (e.g. https://culturin-frontend.vercel.app)
# - Redirect URLs: https://culturin-frontend.vercel.app/auth/callback and http://localhost:3000/auth/callback

# Hosted video iframe origin for Studio `playback_id` embeds (no trailing slash). Required for /stream + inline video dialogs.
# NEXT_PUBLIC_VIDEO_PLAYER_ORIGIN=https://your-player-host.example

# CMS (Payload-style pages API for /articles hero copy — omit in production if you rely on fallbacks only)
NEXT_PUBLIC_CMS_BASE_URL=http://localhost:4000
# Optional: override default Payload page id for /articles landing
# NEXT_PUBLIC_CMS_ARTICLES_LANDING_ID=65b25faecac4c3b01971d7d2
# Optional: only sent when set (never use the literal string "undefined")
# NEXT_PUBLIC_CMS_LOCALE=en

# Legacy (only if you still run old Mongo scripts/routes)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/culturin?retryWrites=true&w=majority
