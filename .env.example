# App
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Database (Supabase Postgres)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# OAuth (NextAuth Google provider)
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# OpenAI (used by /api/chat)
OPENAI_API_KEY=replace-with-openai-api-key

# CMS (used by /articles for remote content)
NEXT_PUBLIC_CMS_BASE_URL=http://localhost:4000

# Clerk (optional; required only if you want Clerk routes/components active)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# Sanity (optional; only needed if you enable private Sanity API usage)
# SANITY_API_TOKEN=replace-with-sanity-api-token

# Legacy (only if you still run old Mongo scripts/routes)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/culturin?retryWrites=true&w=majority
